{
  "expo": {
    "name": "Faith",
    "slug": "faith",
    "version": "1.0.0",
    "scheme": "faith-scheme",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daythreedigital.faith"
    },

    "android": {
      "package": "com.daythreedigital.faith",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptiveIcon.png",
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": ["expo-router"],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "bdee373e-195a-48a0-a387-4b36eca8a9c3"
      }
    },

    "owner": "daythree-digital"
  }
}
